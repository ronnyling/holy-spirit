# Continuous R&D Knowledge Engine — environment configuration.
# Copy to `.env` and fill in real values. NO FALLBACKS: if a required backend is
# unconfigured or unreachable, the engine fails loudly instead of degrading.

# --- Neo4j (graph + native vector index) --------------------------------------
KE_NEO4J_URI=bolt://localhost:7687
KE_NEO4J_USER=neo4j
KE_NEO4J_PASSWORD=knowledge-engine
KE_NEO4J_DATABASE=neo4j

# --- Embeddings (REQUIRED, API-based — no local torch fallback) ----------------
# The dimension MUST match the Neo4j vector index (see KE_EMBEDDING_DIMENSIONS).
KE_EMBEDDING_PROVIDER=openai
KE_EMBEDDING_MODEL=text-embedding-3-small
KE_EMBEDDING_DIMENSIONS=1536
KE_EMBEDDING_API_BASE_URL=
KE_EMBEDDING_API_KEY=

# --- LLM (REQUIRED — claim extraction + semantic gap detection) ----------------
KE_LLM_PROVIDER=mimo
KE_MIMO_API_BASE_URL=
KE_MIMO_API_KEY=
KE_MIMO_MODEL=mimo-2.5

# --- Storage layout ------------------------------------------------------------
KE_DATA_DIR=./data
KE_WIKI_DIR=./wiki

# --- Chunking ------------------------------------------------------------------
KE_CHUNK_MAX_CHARS=1200
KE_CHUNK_OVERLAP_CHARS=150
KE_CHUNK_MIN_CHARS=200
