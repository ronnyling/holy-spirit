# Continuous R&D Knowledge Engine — environment configuration.
# Copy to `.env` and fill in real values. NO FALLBACKS: if a required backend is
# unconfigured or unreachable, the engine fails loudly instead of degrading.

# --- Neo4j (graph + native vector index) --------------------------------------
KE_NEO4J_URI=bolt://localhost:7687
KE_NEO4J_USER=neo4j
KE_NEO4J_PASSWORD=knowledge-engine
KE_NEO4J_DATABASE=neo4j

# --- Embeddings (REQUIRED) ----------------------------------------------------
# The dimension MUST match the Neo4j vector index (see KE_EMBEDDING_DIMENSIONS).
# Local option (no key): Ollama serving bge-m3 (1024-dim). KE_EMBEDDING_KEEP_ALIVE
# governs housekeeping — "0" unloads the model from RAM right after each call so it
# only runs during ingestion/chunking or search; "5m" keeps it warm.
KE_EMBEDDING_PROVIDER=ollama
KE_EMBEDDING_MODEL=bge-m3
KE_EMBEDDING_DIMENSIONS=1024
KE_EMBEDDING_API_BASE_URL=http://localhost:11434
KE_EMBEDDING_API_KEY=
KE_EMBEDDING_KEEP_ALIVE=0
# num_ctx = input context per embed call (tokens). 1k keeps RAM low; bge-m3
# truncates longer inputs, so ingestion batches short claim statements instead.
KE_EMBEDDING_NUM_CTX=1024
# Max texts per embed request; longer lists are split into sequential batches.
KE_EMBEDDING_BATCH_SIZE=64

# --- LLM (REQUIRED — claim extraction + semantic gap detection) ----------------
# HIGH priority tasks (claim extraction, evidence extraction, synthesis):
KE_LLM_PROVIDER=mimo
KE_MIMO_API_BASE_URL=
KE_MIMO_API_KEY=
KE_MIMO_MODEL=mimo-2.5

# LOW priority tasks (unstated assumptions, simple classification):
# Single SLM model (qwen3:4b) handles ALL low-priority generative tasks
KE_OLLAMA_SLM_MODEL=qwen3:4b
KE_OLLAMA_BASE_URL=http://localhost:11434
KE_OLLAMA_DISABLED=false

# Embedding model (already required for vector search)
KE_EMBEDDING_MODEL=bge-m3

# --- Storage layout ------------------------------------------------------------
KE_DATA_DIR=./data
KE_WIKI_DIR=./wiki

# --- Chunking ------------------------------------------------------------------
KE_CHUNK_MAX_CHARS=1200
KE_CHUNK_OVERLAP_CHARS=150
KE_CHUNK_MIN_CHARS=200

# --- Reranker (optional — embedding-based retrieval precision) ------------------
# Uses Ollama /api/embed to embed query + documents, then cosine similarity.
# When enabled, top retrieval results are reranked. Fails loudly on error.
KE_RERANKER_PROVIDER=none          # ollama | none
KE_RERANKER_MODEL=                 # e.g. bona/bge-reranker-v2-m3
KE_RERANKER_API_BASE_URL=http://localhost:11434
KE_RERANKER_KEEP_ALIVE=0

# --- Query processing (optional — retrieval quality) ----------------------------
# Domain-aware expansion adds synonyms; decomposition splits complex queries.
# Both are bounded by KE_QUERY_MAX_LLM_CALLS to control API costs.
KE_QUERY_EXPAND=false
KE_QUERY_DECOMPOSE=false
KE_QUERY_MAX_LLM_CALLS=3

# --- Cache (optional — retrieval performance) -----------------------------------
# Bounded LRU cache with TTL for query-path embeddings. Ingestion-path is uncached.
KE_CACHE_MAX_SIZE=1000
KE_CACHE_TTL_SECONDS=3600
